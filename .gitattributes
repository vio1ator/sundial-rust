# Git LFS configuration for Sundial reference data
# Large tensor files should be tracked with Git LFS

# Reference tensors from Python
tests/reference_data/*.npy filter=lfs diff=lfs merge=lfs -text
tests/reference_data/**/*.npy filter=lfs diff=lfs merge=lfs -text

# Cache files (large model weights, intermediate results)
model_cache/** filter=lfs diff=lfs merge=lfs -text
test_cache/** filter=lfs diff=lfs merge=lfs -text

# Weights files
weights/**/*.safetensors filter=lfs diff=lfs merge=lfs -text
weights/**/*.bin filter=lfs diff=lfs merge=lfs -text
